{
  "name": "xtab",
  "version": "0.1.0",
  "description": "Framework-agnostic crosstab / pivot table UI for tabular JavaScript datasets.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "crosstab",
    "pivot",
    "pivot-table",
    "table",
    "data",
    "analytics"
  ],
  "main": "./dist/xtab.umd.cjs",
  "module": "./dist/xtab.js",
  "exports": {
    ".": {
      "import": "./dist/xtab.js",
      "require": "./dist/xtab.umd.cjs"
    },
    "./style.css": "./src/xtab.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}
